APP_NAME=MediConsult
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# URL du frontend (pour CORS et emails de reset)
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mediconsult_db
DB_USERNAME=postgres
DB_PASSWORD=

BROADCAST_DRIVER=log
# En developpement local : utiliser file (pas besoin de Redis)
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (optionnel - pour la production uniquement)
# CACHE_DRIVER=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mediconsult.sn"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost:3000

# Cle de chiffrement des donnees medicales (AES-256)
MEDICAL_DATA_ENCRYPTION_KEY=

# ============================================
# PRODUCTION (Railway) -- decommentez et remplissez
# ============================================
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://votre-backend.railway.app
# FRONTEND_URL=https://votre-app.vercel.app
# SANCTUM_STATEFUL_DOMAINS=votre-app.vercel.app
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}
# DB_DATABASE=${{Postgres.PGDATABASE}}
# DB_USERNAME=${{Postgres.PGUSER}}
# DB_PASSWORD=${{Postgres.PGPASSWORD}}
